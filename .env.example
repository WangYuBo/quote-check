# 环境变量样板——与 lib/env.ts 的 Zod schema 一一对应
# CI 检查：bun run test:env-sync（spec-coding §19/§20）
# 敏感值请放 .env.local 或 Vercel Project Settings → Environment Variables
# 严禁提交真实密钥到本仓库

# 运行环境（development / test / production）
NODE_ENV=development

# 数据库：Neon Postgres 连接串（含 sslmode=require）
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/quotecheck?sslmode=require

# Better Auth（ADR-004）
BETTER_AUTH_SECRET=replace-with-32+-random-chars-from-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# 硅基流动（DeepSeek V3.2 接入端点；ADR-005）
SILICONFLOW_API_KEY=sk-replace-me

# Vercel Blob（书稿/参考上传 + TTL 销毁；ADR-010）
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me

# Inngest（长任务工作流；ADR-002）
INNGEST_EVENT_KEY=replace-me
INNGEST_SIGNING_KEY=signkey-replace-me

# 日志级别（trace/debug/info/warn/error）
LOG_LEVEL=info

# 成本门闸（CNY；real.md #6 · 超额暂停）
COST_CAP_CNY=50

# 书稿销毁 TTL（天；real.md #3）
TTL_DAYS=7

# 演示模式（跳过 LLM 真调用，返回 fixture；本地 demo）
DEMO_MODE=false
