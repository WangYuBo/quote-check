{
  "name": "quote-check",
  "version": "1.0.0-scaffold",
  "private": true,
  "description": "文史类引用校对软件 v1.0 — 三维度核查（字词/解释/语境），编辑决定、机器不判错",
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "bun@1.1.38",
  "scripts": {
    "dev": "env -u http_proxy -u https_proxy next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:contract": "DOCKER_HOST=${DOCKER_HOST:-unix:///Users/wangyubo/.docker/run/docker.sock} vitest run tests/contract",
    "test:compliance": "vitest run tests/compliance",
    "test:prompts": "vitest run tests/compliance/prompt-integrity.test.ts",
    "test:neutral": "vitest run tests/compliance/neutral-tone.test.ts",
    "test:env-sync": "tsx scripts/check-env-sync.ts",
    "test:prompt-frozen": "tsx scripts/check-prompt-frozen.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:triggers": "bun scripts/db-apply-triggers.ts",
    "db:check": "bun scripts/db-check.ts",
    "ai:smoke": "bun scripts/ai-smoke.ts",
    "db:cleanup-smoke": "bun scripts/db-cleanup-smoke.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "0.0.72",
    "@neondatabase/serverless": "0.10.4",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/blob": "0.27.0",
    "ai": "3.4.33",
    "better-auth": "0.7.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "drizzle-orm": "0.36.4",
    "inngest": "^4.2.4",
    "lucide-react": "^1.11.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "opencc-js": "1.0.5",
    "pino": "9.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@playwright/test": "1.49.1",
    "@tailwindcss/postcss": "4.2.2",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "22.10.5",
    "@types/opencc-js": "1.0.3",
    "@types/pg": "^8.20.0",
    "@types/react": "19.0.5",
    "@types/react-dom": "19.0.2",
    "@vitest/coverage-v8": "2.1.8",
    "drizzle-kit": "0.29.1",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.6",
    "pg": "^8.20.0",
    "pino-pretty": "13.0.0",
    "postcss": "8.5.0",
    "prettier": "3.4.2",
    "tailwindcss": "4.2.2",
    "testcontainers": "^11.14.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.19.0",
    "vitest": "2.1.8"
  }
}
